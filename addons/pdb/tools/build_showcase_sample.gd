	_add(db, _const(&"Economy", "config", "Gold, vendor and repair economy.", {"starting_gold": 50, "vendor_markup": 1.5, "repair_cost_per_point": 2}))
	_add(db, _const(&"CombatTuning", "config", "Armor, dodge and block formulas.", {"armor_k": 0.06, "dodge_cap": 0.4, "block_value": 0.25}))
	_add(db, _const(&"WorldSettings", "config", "World tuning constants.", {"gravity": -9.8, "tile_size": 64, "day_length_sec": 1200.0}))
	_add(db, _const(&"UITheme", "config", "Named UI colors (Color-valued constants).", {"accent": Color(0.36, 0.62, 1.0), "danger": Color(0.85, 0.24, 0.24), "gold": Color(0.95, 0.78, 0.25)}))
