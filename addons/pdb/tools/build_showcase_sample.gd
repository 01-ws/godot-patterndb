@tool
extends EditorScript
## Seed generator for the PatternDB showcase database. Run from the editor:
## File → Run (Ctrl/Cmd+Shift+X) with this script open. Regenerates
## res://sample_rpg_database.pdb with a broad tour of PatternDB features:
## enums, constants (incl. vector/color values), multi-level inheritance,
## every common and exotic field type, hierarchical dot-path tags, and a
## web of cross-instance references (quest chains, skill/dialogue trees,
## recipes, loot tables, faction relations, merchant stock).

const OUT_PATH := "res://sample_rpg_database.pdb"

func _run() -> void:
	var db := PatternDatabaseFile.new()
	db.ensure_uid()
	db.version = 3
	db.meta_data = {
		"name": "RPG Showcase",
		"note": "Generated by build_showcase_sample.gd — a feature tour, not a real game.",
		"export_dir": "res://data/generated",
		"enum_class": "enums",
		"const_class": "consts",
	}

	_build_enums(db)
	_build_consts(db)
	_build_definitions(db)
	_build_instances(db)

	var err := _write_pdb(db)
	if err == OK:
		print("[PatternDB] Wrote %s — %d patterns." % [OUT_PATH, db.patterns.size()])
		if Engine.is_editor_hint():
			EditorInterface.get_resource_filesystem().scan()
	else:
		push_error("[PatternDB] Save failed (error %d)." % err)

func _write_pdb(db: PatternDatabaseFile) -> Error:
	var saver := PdbSaver.new()
	var err: Error = saver._save(db, OUT_PATH, 0)
	if err == OK:
		return OK
	var tmp := "user://.__pdb_showcase_tmp.tres"
	var old_path := db.resource_path
	db.resource_path = tmp
	err = ResourceSaver.save(db, tmp)
	db.resource_path = old_path
	if err != OK:
		return err
	var text := FileAccess.get_file_as_string(tmp)
	if text.is_empty():
		return ERR_FILE_CANT_READ
	var dst := FileAccess.open(OUT_PATH, FileAccess.WRITE)
	if dst == null:
		return FileAccess.get_open_error()
	dst.store_string(text)
	dst.close()
	if FileAccess.file_exists(tmp):
		DirAccess.remove_absolute(ProjectSettings.globalize_path(tmp))
	return OK

