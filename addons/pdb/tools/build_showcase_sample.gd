func _add(db: PatternDatabaseFile, p: PdbPattern) -> void:
	db.patterns[p.id] = p

func _enum(id: StringName, tag: String, desc: String, values: Dictionary) -> PdbEnum:
	var e := PdbEnum.new()
	e.id = id
	if tag != "": e.add_tag(tag)
	e.description = desc
	e.values = values
	return e

func _const(id: StringName, tag: String, desc: String, data: Dictionary) -> PdbConst:
	var c := PdbConst.new()
	c.id = id
	if tag != "": c.add_tag(tag)
	c.description = desc
	c.data = data
	return c

func _field(fname: StringName, ftype: int, hint: int = PROPERTY_HINT_NONE, hint_string: String = "", group: String = "", desc: String = "", required: bool = false, default = null) -> PdbFieldDefinition:
	var f := PdbFieldDefinition.new()
	f.field_name = fname
	f.field_type = ftype
	f.hint = hint
	f.hint_string = hint_string
	f.export_group = group
	f.description = desc
	f.required = required
	f.default_value = default
	return f

func _def(id: StringName, tag: String, desc: String, extends_type: String, icon: String, fields: Array) -> PdbModelDefinition:
	var d := PdbModelDefinition.new()
	d.id = id
	if tag != "": d.add_tag(tag)
	d.description = desc
	d.extends_type = extends_type
	d.icon_name = icon
	d.fields.assign(fields)
	return d

func _inst(id: StringName, def_id: StringName, tags: Array, data: Dictionary) -> PdbModelInstance:
	var i := PdbModelInstance.new()
	i.id = id
	i.definition_id = def_id
	for t in tags:
		if t != "":
			i.add_tag(t)
	i.data = data
	return i
